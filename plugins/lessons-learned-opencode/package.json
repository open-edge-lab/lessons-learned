{
  "name": "lessons-learned-opencode",
  "version": "0.2.0",
  "description": "OpenCode plugin for the lessons-learned knowledge base — Karpathy-LLM-Wiki-style problem-solving insights in any repo",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "sync-core": "bun ../../scripts/sync-core.mjs",
    "build": "bun ../../scripts/sync-core.mjs && tsc --emitDeclarationOnly && bun build src/index.ts --outdir dist --target node",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "bun run build",
    "test": "bun test"
  },
  "keywords": [
    "opencode",
    "lessons-learned",
    "knowledge-base",
    "wiki",
    "agent",
    "llm"
  ],
  "author": "Open Edge",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/open-edge-lab/lessons-learned.git",
    "directory": "plugins/lessons-learned-opencode"
  },
  "bugs": {
    "url": "https://github.com/open-edge-lab/lessons-learned/issues"
  },
  "homepage": "https://github.com/open-edge-lab/lessons-learned#readme",
  "peerDependencies": {
    "@opencode-ai/plugin": ">=0.15.0"
  },
  "devDependencies": {
    "@opencode-ai/plugin": "^0.15.0",
    "@types/bun": "^1.3.1",
    "typescript": "^5.9.3"
  }
}
